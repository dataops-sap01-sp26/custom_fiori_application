<mvc:View xmlns:core="sap.ui.core" xmlns:mvc="sap.ui.core.mvc" xmlns="sap.m" xmlns:macros="sap.fe.macros"
    xmlns:tnt="sap.tnt" xmlns:html="http://www.w3.org/1999/xhtml"
    xmlns:viz="sap.viz.ui5.controls"
    xmlns:viz.data="sap.viz.ui5.data"
    xmlns:viz.feeds="sap.viz.ui5.controls.common.feeds"
    xmlns:l="sap.ui.layout"
    controllerName="z.sap01.cfa.ext.view.Main">
    <tnt:ToolPage id="toolPage">
        <!-- HEADER -->
        <tnt:header>
            <tnt:ToolHeader>
                <Button id="sideNavigationToggleButton" icon="sap-icon://menu2" type="Transparent" press=".onMenuButtonPress" />
                <Title text="SAP Job Operations Dashboard" />
                <ToolbarSpacer />
                <Button icon="sap-icon://bell" type="Transparent" tooltip="Notifications" />
                <Button id="userMenuButton" icon="sap-icon://customer" type="Transparent" tooltip="User Profile" press=".onUserMenuPress" />
            </tnt:ToolHeader>
        </tnt:header>
        
        <!-- SIDEBAR MENU -->
        <tnt:sideContent>
            <tnt:SideNavigation id="sideNavigation" expanded="true" itemSelect=".onItemSelect">
                <tnt:NavigationList>
                    <!-- Nhóm 1: Overview & Analytics -->
                    <tnt:NavigationListItem text="Dashboard Home" icon="sap-icon://home" key="dashboard" />
                    <!-- <tnt:NavigationListItem text="Analytics &amp; Charts" icon="sap-icon://business-objects-experience" key="analytics" /> -->
                    
                    <!-- Nhóm 2: Core Master Data -->
                    <tnt:NavigationListItem text="Master Data" icon="sap-icon://database">
                        <tnt:NavigationListItem text="Report Catalog" icon="sap-icon://education" key="catalog" />
                        <tnt:NavigationListItem text="Subscriptions" icon="sap-icon://form" key="subscriptions" />
                    </tnt:NavigationListItem>

                    <!-- Nhóm 3: Operations & Monitoring -->
                    <tnt:NavigationListItem text="Job Operations" icon="sap-icon://process">
                        <tnt:NavigationListItem text="Job Configurations" icon="sap-icon://action-settings" key="jobconfigs" />
                        <tnt:NavigationListItem text="Job History &amp; Logs" icon="sap-icon://history" key="history" />
                    </tnt:NavigationListItem>

                    <!-- Nhóm 4: Outputs -->
                    <tnt:NavigationListItem text="Output &amp; Deliverables" icon="sap-icon://documents">
                        <tnt:NavigationListItem text="My Exports (Files)" icon="sap-icon://download" key="exports" />
                    </tnt:NavigationListItem>

                    <!-- Nhóm 5: Reports -->
                    <tnt:NavigationListItem text="Reports" icon="sap-icon://manager-insight">
                        <tnt:NavigationListItem text="Report AP-01" icon="sap-icon://money-bills" key="report_ap01" />
                        <tnt:NavigationListItem text="Report AP-02" icon="sap-icon://supplier" key="report_ap02" />
                        <tnt:NavigationListItem text="Report AP-03" icon="sap-icon://payment-approval" key="report_ap03" />
                        <tnt:NavigationListItem text="Report AR-01" icon="sap-icon://customer-financial-fact-sheet" key="report_ar01" />
                        <tnt:NavigationListItem text="Report AR-02" icon="sap-icon://receipt" key="report_ar02" />
                        <tnt:NavigationListItem text="Report AR-03" icon="sap-icon://sales-document" key="report_ar03" />
                        <tnt:NavigationListItem text="Report GL-01" icon="sap-icon://accounting-document-verification" key="report_gl01" />
                    </tnt:NavigationListItem>
                </tnt:NavigationList>
                
                <!-- Fixed Bottom Item -->
                <tnt:fixedItem>
                    <tnt:NavigationList>
                        <tnt:NavigationListItem text="Settings &amp; Parameters" icon="sap-icon://settings" key="settings" />
                    </tnt:NavigationList>
                </tnt:fixedItem>
            </tnt:SideNavigation>
        </tnt:sideContent>
        
        <!-- MAIN CONTENT ÁP VỚI TỪNG MENU BÊN TRÁI -->
        <tnt:mainContents>
            <NavContainer id="pageContainer">
                <pages>
                    <!-- ══════════════════════════════════════════════════════════════ -->
                    <!-- DASHBOARD HOME PAGE                                            -->
                    <!-- ══════════════════════════════════════════════════════════════ -->
                    <ScrollContainer id="dashboard" horizontal="false" vertical="true" height="100%">
                        <VBox class="sapUiResponsiveMargin drsPageContent">
                            
                            <!-- WELCOME BANNER -->
                            <HBox class="drsWelcomeBanner sapUiMediumMarginBottom" alignItems="Center" visible="{= ${userSession>/isLoaded} }">
                                <core:Icon src="sap-icon://hello-world" size="2rem" class="sapUiSmallMarginEnd drsWelcomeIcon"/>
                                <Text text="{i18n>welcomeBack} {userSession>/userFullName}, {i18n>loggedInAs} {userSession>/roleName}" class="drsWelcomeText"/>
                            </HBox>
                            
                            <!-- SECTION 1: KPI Overview -->
                            <VBox class="sapUiMediumMarginBottom drsSection">
                                <Title id="kpiTitle" text="{i18n>systemOverview}" level="H3" class="drsSectionTitle"/>
                                <HBox id="kpiTilesBox" wrap="Wrap" class="drsKpiTileContainer">
                                    <!-- Reports Available -->
                                    <GenericTile
                                        id="tileReports"
                                        class="drsKpiTile"
                                        header="{i18n>reportsAvailable}"
                                        press=".onKpiTilePress">
                                        <customData>
                                            <core:CustomData key="targetPage" value="catalog"/>
                                        </customData>
                                        <TileContent>
                                            <NumericContent
                                                value="{dashboard>/reportCount}"
                                                icon="sap-icon://document"
                                                valueColor="Neutral"/>
                                        </TileContent>
                                    </GenericTile>
                                    
                                    <!-- Total Subscriptions -->
                                    <GenericTile
                                        id="tileTotalSubscr"
                                        class="drsKpiTile"
                                        header="{i18n>totalSubscriptions}"
                                        press=".onKpiTilePress">
                                        <customData>
                                            <core:CustomData key="targetPage" value="subscriptions"/>
                                        </customData>
                                        <TileContent>
                                            <NumericContent
                                                value="{dashboard>/totalSubscriptions}"
                                                icon="sap-icon://email"
                                                valueColor="Neutral"/>
                                        </TileContent>
                                    </GenericTile>
                                    
                                    <!-- Active Subscriptions -->
                                    <GenericTile
                                        id="tileActiveSubscr"
                                        class="drsKpiTile"
                                        header="{i18n>activeSubscriptions}"
                                        press=".onKpiTilePress">
                                        <customData>
                                            <core:CustomData key="targetPage" value="subscriptions"/>
                                        </customData>
                                        <TileContent>
                                            <NumericContent
                                                value="{dashboard>/activeSubscriptions}"
                                                icon="sap-icon://activate"
                                                valueColor="Good"/>
                                        </TileContent>
                                    </GenericTile>
                                    
                                    <!-- Scheduled Jobs -->
                                    <GenericTile
                                        id="tileScheduledJobs"
                                        class="drsKpiTile"
                                        header="{i18n>scheduledJobs}"
                                        press=".onKpiTilePress">
                                        <customData>
                                            <core:CustomData key="targetPage" value="jobconfigs"/>
                                        </customData>
                                        <TileContent>
                                            <NumericContent
                                                value="{dashboard>/scheduledJobs}"
                                                icon="sap-icon://appointment"
                                                valueColor="Neutral"/>
                                        </TileContent>
                                    </GenericTile>
                                    
                                    <!-- Failed Jobs -->
                                    <GenericTile
                                        id="tileFailedJobs"
                                        class="drsKpiTile"
                                        header="{i18n>failedJobs}"
                                        press=".onKpiTilePress">
                                        <customData>
                                            <core:CustomData key="targetPage" value="history"/>
                                        </customData>
                                        <TileContent>
                                            <NumericContent
                                                value="{dashboard>/failedJobs}"
                                                icon="sap-icon://alert"
                                                valueColor="{= ${dashboard>/failedJobs} > 0 ? 'Error' : 'Neutral'}"/>
                                        </TileContent>
                                    </GenericTile>
                                    
                                    <!-- Finished Jobs (JobStatus F) -->
                                    <GenericTile
                                        id="tileFinishedJobs"
                                        class="drsKpiTile"
                                        header="{i18n>finishedJobs}"
                                        press=".onKpiTilePress">
                                        <customData>
                                            <core:CustomData key="targetPage" value="jobconfigs"/>
                                        </customData>
                                        <TileContent>
                                            <NumericContent
                                                value="{dashboard>/finishedJobs}"
                                                icon="sap-icon://accept"
                                                valueColor="{= ${dashboard>/finishedJobs} > 0 ? 'Good' : 'Neutral'}"/>
                                        </TileContent>
                                    </GenericTile>
                                    
                                    <!-- Cancelled Jobs (JobStatus C) -->
                                    <GenericTile
                                        id="tileCancelJobs"
                                        class="drsKpiTile"
                                        header="{i18n>cancelJobs}"
                                        press=".onKpiTilePress">
                                        <customData>
                                            <core:CustomData key="targetPage" value="jobconfigs"/>
                                        </customData>
                                        <TileContent>
                                            <NumericContent
                                                value="{dashboard>/cancelledJobs}"
                                                icon="sap-icon://cancel"
                                                valueColor="Neutral"/>
                                        </TileContent>
                                    </GenericTile>
                                </HBox>
                            </VBox>
                            
                            <!-- SECTION 2: Quick Actions -->
                            <VBox class="sapUiMediumMarginBottom drsSection">
                                <Title id="actionsTitle" text="{i18n>quickActions}" level="H3" class="drsSectionTitle"/>
                                <HBox id="actionTilesBox" wrap="Wrap" class="drsKpiTileContainer">
                                    <GenericTile
                                        id="actionBrowseReports"
                                        class="drsQuickActionTile"
                                        header="{i18n>browseReports}"
                                        subheader="{i18n>browseReportsDesc}"
                                        press=".onQuickActionPress">
                                        <customData>
                                            <core:CustomData key="targetPage" value="catalog"/>
                                        </customData>
                                        <TileContent>
                                            <ImageContent src="sap-icon://document"/>
                                        </TileContent>
                                    </GenericTile>
                                    
                                    <GenericTile
                                        id="actionMySubscr"
                                        class="drsQuickActionTile"
                                        header="{i18n>mySubscriptions}"
                                        subheader="{i18n>mySubscriptionsDesc}"
                                        press=".onQuickActionPress">
                                        <customData>
                                            <core:CustomData key="targetPage" value="subscriptions"/>
                                        </customData>
                                        <TileContent>
                                            <ImageContent src="sap-icon://email"/>
                                        </TileContent>
                                    </GenericTile>
                                    
                                    <GenericTile
                                        id="actionJobMonitor"
                                        class="drsQuickActionTile"
                                        header="{i18n>jobMonitor}"
                                        subheader="{i18n>jobMonitorDesc}"
                                        press=".onQuickActionPress">
                                        <customData>
                                            <core:CustomData key="targetPage" value="jobconfigs"/>
                                        </customData>
                                        <TileContent>
                                            <ImageContent src="sap-icon://settings"/>
                                        </TileContent>
                                    </GenericTile>
                                    
                                    <GenericTile
                                        id="actionJobHistory"
                                        class="drsQuickActionTile"
                                        header="{i18n>jobHistory}"
                                        subheader="{i18n>jobHistoryDesc}"
                                        press=".onQuickActionPress">
                                        <customData>
                                            <core:CustomData key="targetPage" value="history"/>
                                        </customData>
                                        <TileContent>
                                            <ImageContent src="sap-icon://history"/>
                                        </TileContent>
                                    </GenericTile>
                                    
                                    <GenericTile
                                        id="actionMyExports"
                                        class="drsQuickActionTile"
                                        header="{i18n>myExports}"
                                        subheader="{i18n>myExportsDesc}"
                                        press=".onQuickActionPress">
                                        <customData>
                                            <core:CustomData key="targetPage" value="exports"/>
                                        </customData>
                                        <TileContent>
                                            <ImageContent src="sap-icon://open-folder"/>
                                        </TileContent>
                                    </GenericTile>
                                </HBox>
                            </VBox>
                            
                            <!-- SECTION 3: Job Execution Trend Chart -->
                            <VBox class="drsChartContainer">
                                <Title id="chartTitle" text="{i18n>jobTrend}" level="H3" class="drsSectionTitle"/>
                                <viz:VizFrame
                                    id="dashboardChart"
                                    vizType="stacked_column"
                                    height="300px"
                                    width="100%">
                                    <viz:dataset>
                                        <viz.data:FlattenedDataset data="{dashboard>/chartData}">
                                            <viz.data:dimensions>
                                                <viz.data:DimensionDefinition name="Date" value="{dashboard>JobDate}"/>
                                                <viz.data:DimensionDefinition name="Status" value="{dashboard>JobStatus}"/>
                                            </viz.data:dimensions>
                                            <viz.data:measures>
                                                <viz.data:MeasureDefinition name="Count" value="{dashboard>JobCountTotal}"/>
                                            </viz.data:measures>
                                        </viz.data:FlattenedDataset>
                                    </viz:dataset>
                                    <viz:feeds>
                                        <viz.feeds:FeedItem id="feedCategoryAxis" type="Dimension" uid="categoryAxis" values="Date"/>
                                        <viz.feeds:FeedItem id="feedColor" type="Dimension" uid="color" values="Status"/>
                                        <viz.feeds:FeedItem id="feedValueAxis" type="Measure" uid="valueAxis" values="Count"/>
                                    </viz:feeds>
                                </viz:VizFrame>
                            </VBox>
                            
                            <!-- SECTION 4: Recent Subscriptions -->
                            <VBox class="drsTableSection">
                                <HBox id="recentSubscrHeader" justifyContent="SpaceBetween" alignItems="Center" class="drsSectionTitle">
                                    <Title id="recentSubscrTitle" text="{i18n>recentSubscriptions}" level="H3"/>
                                    <Link id="viewAllSubscrLink" text="{i18n>viewAll}" press=".onViewAllSubscriptions"/>
                                </HBox>
                                <Table
                                    id="recentSubscriptionsTable"
                                    inset="false"
                                    noDataText="{i18n>noSubscriptions}"
                                    items="{dashboard>/recentSubscriptions}">
                                    <columns>
                                        <Column id="colSubscrId" width="15%"><Text text="{i18n>subscriptionId}"/></Column>
                                        <Column id="colReportId" width="12%"><Text text="{i18n>reportId}"/></Column>
                                        <Column id="colSubscrName" width="25%"><Text text="{i18n>description}"/></Column>
                                        <Column id="colSubscrStatus" width="12%" hAlign="Center"><Text text="{i18n>status}"/></Column>
                                        <Column id="colFormat" width="10%"><Text text="{i18n>format}"/></Column>
                                        <Column id="colEmail" width="26%"><Text text="{i18n>emailTo}"/></Column>
                                    </columns>
                                    <items>
                                        <ColumnListItem type="Active" press=".onSubscriptionRowPress">
                                            <Text text="{dashboard>SubscrId}"/>
                                            <Text text="{dashboard>ReportId}"/>
                                            <Text text="{dashboard>SubscrName}"/>
                                            <ObjectStatus
                                                text="{dashboard>Status}"
                                                state="{= ${dashboard>Status} === 'A' ? 'Success' : 'Warning'}"
                                                icon="{= ${dashboard>Status} === 'A' ? 'sap-icon://accept' : 'sap-icon://pause'}"/>
                                            <Text text="{dashboard>OutputFormat}"/>
                                            <Text text="{dashboard>EmailTo}"/>
                                        </ColumnListItem>
                                    </items>
                                </Table>
                            </VBox>
                            
                            <!-- SECTION 5: Recent Jobs -->
                            <VBox class="drsTableSection">
                                <HBox id="recentJobsHeader" justifyContent="SpaceBetween" alignItems="Center" class="drsSectionTitle">
                                    <Title id="recentJobsTitle" text="{i18n>recentJobs}" level="H3"/>
                                    <Link id="viewAllJobsLink" text="{i18n>viewAll}" press=".onViewAllJobs"/>
                                </HBox>
                                <Table
                                    id="recentJobsTable"
                                    inset="false"
                                    noDataText="{i18n>noJobs}"
                                    items="{dashboard>/recentJobs}">
                                    <columns>
                                        <Column id="colJobId" width="15%"><Text text="{i18n>jobId}"/></Column>
                                        <Column id="colJobText" width="30%"><Text text="{i18n>description}"/></Column>
                                        <Column id="colJobStatus" width="15%" hAlign="Center"><Text text="{i18n>status}"/></Column>
                                        <Column id="colCreatedAt" width="20%"><Text text="{i18n>startedAt}"/></Column>
                                        <Column id="colJobSubscrId" width="20%"><Text text="{i18n>subscriptionId}"/></Column>
                                    </columns>
                                    <items>
                                        <ColumnListItem type="Active" press=".onJobRowPress">
                                            <Text text="{dashboard>JobId}"/>
                                            <Text text="{dashboard>JobText}"/>
                                            <ObjectStatus
                                                text="{dashboard>JobStatusText}"
                                                state="{= ${dashboard>JobStatus} === 'F' ? 'Success' : (${dashboard>JobStatus} === 'A' ? 'Error' : 'Warning')}"
                                                icon="{= ${dashboard>JobStatus} === 'F' ? 'sap-icon://accept' : (${dashboard>JobStatus} === 'A' ? 'sap-icon://error' : 'sap-icon://process')}"/>
                                            <Text text="{dashboard>CreatedAt}"/>
                                            <Text text="{dashboard>SubscrId}"/>
                                        </ColumnListItem>
                                    </items>
                                </Table>
                            </VBox>
                            
                        </VBox>
                    </ScrollContainer>
                    <!-- <ScrollContainer id="analytics" horizontal="false" vertical="true">
                        <Title text="Job History Analytics" class="sapUiMediumMargin"/>
                    </ScrollContainer> -->
                    
                    <!-- ── REPORT CATALOG TAB ── -->
                    <ScrollContainer id="catalog" horizontal="false" vertical="true" height="100%">
                        <VBox class="sapUiResponsiveMargin drsPageContent">
                            <!-- Tile Container (populated dynamically) -->
                            <VBox id="catalogTileContainer" class="drsCatalogContainer"/>
                        </VBox>
                    </ScrollContainer>
                    
                    <!-- ── SUBSCRIPTIONS TAB ── -->
                    <ScrollContainer id="subscriptions" horizontal="false" vertical="true" height="100%">
                        <VBox class="sapUiResponsiveMargin drsPageContent">
                            <macros:FilterBar
                                id="subscrFilterBar"
                                metaPath="/DrsSubscription/@com.sap.vocabularies.UI.v1.SelectionFields"
                                liveMode="false"/>
                            <macros:Table
                                id="subscrTable"
                                metaPath="/DrsSubscription/@com.sap.vocabularies.UI.v1.LineItem"
                                readOnly="true"
                                enableExport="true"
                                enableAutoColumnWidth="true"
                                variantManagement="Control"
                                p13nMode="Column,Sort,Filter"
                                headerText="Subscriptions"
                                filterBar="subscrFilterBar"
                                growingThreshold="20">
                                <macros:actions>
                                    <macros:Action key="customCreate" text="Create" press=".onCreateSubscription" requiresSelection="false" />
                                    <macros:Action key="customDelete" text="Delete" press=".onDeleteSubscription" requiresSelection="true" />
                                </macros:actions>
                            </macros:Table>
                        </VBox>
                    </ScrollContainer>
                    
                    <ScrollContainer id="jobconfigs" horizontal="false" vertical="true" height="100%">
                        <VBox class="sapUiResponsiveMargin drsPageContent">
                            <macros:FilterBar
                                id="jobConfigFilterBar"
                                metaPath="/DrsJobConfig/@com.sap.vocabularies.UI.v1.SelectionFields"
                                liveMode="false"/>
                            <macros:Table
                                id="jobConfigTable"
                                metaPath="/DrsJobConfig/@com.sap.vocabularies.UI.v1.LineItem"
                                readOnly="true"
                                enableExport="true"
                                enableAutoColumnWidth="true"
                                variantManagement="Control"
                                p13nMode="Column,Sort,Filter"
                                headerText="Job Configurations"
                                filterBar="jobConfigFilterBar"
                                growingThreshold="20">
                                <macros:actions>
                                    <macros:Action key="customCreate" text="Create" press=".onCreateJobConfig" requiresSelection="false" />
                                    <macros:Action key="customDelete" text="Delete" press=".onDeleteJobConfig" requiresSelection="true" />
                                </macros:actions>
                            </macros:Table>
                        </VBox>
                    </ScrollContainer>

                    <ScrollContainer id="history" horizontal="false" vertical="true" height="100%">
                        <VBox class="sapUiResponsiveMargin drsPageContent">
                            <macros:FilterBar
                                id="jobHistoryFilterBar"
                                metaPath="/JobHistoryAnalytics/@com.sap.vocabularies.UI.v1.SelectionFields"
                                liveMode="false"
                                search=".onJobHistoryFilterSearch"/>

                            <!-- Chart Section — VizFrame thuần, không dùng macros:Chart -->
                            <Panel id="jobHistoryChartPanel" headerText="Job Execution Statistics" class="drsSection">
                                <viz:VizFrame
                                    id="jobTrendChart"
                                    vizType="stacked_column"
                                    height="350px"
                                    width="100%">
                                    <viz:dataset>
                                        <viz.data:FlattenedDataset data="{chartModel>/chartData}">
                                            <viz.data:dimensions>
                                                <viz.data:DimensionDefinition name="Date"   value="{chartModel>JobDate}"/>
                                                <viz.data:DimensionDefinition name="Status" value="{chartModel>JobStatus}"/>
                                            </viz.data:dimensions>
                                            <viz.data:measures>
                                                <viz.data:MeasureDefinition name="Count" value="{chartModel>JobCountTotal}"/>
                                        </viz.data:measures>
                                    </viz.data:FlattenedDataset>
                                </viz:dataset>
                                <viz:feeds>
                                    <viz.feeds:FeedItem uid="categoryAxis" type="Dimension" values="Date"/>
                                    <viz.feeds:FeedItem uid="valueAxis"    type="Measure"   values="Count"/>
                                    <viz.feeds:FeedItem uid="color"        type="Dimension" values="Status"/>
                                </viz:feeds>
                            </viz:VizFrame>
                        </Panel>

                            <macros:Table
                                id="jobHistoryTable"
                                metaPath="/JobHistoryAnalytics/@com.sap.vocabularies.UI.v1.LineItem"
                                readOnly="true"
                                enableExport="true"
                                enableAutoColumnWidth="true"
                                variantManagement="Control"
                                p13nMode="Column,Sort,Filter"
                                headerText="Global Job History"
                                filterBar="jobHistoryFilterBar"
                                growingThreshold="20">
                            </macros:Table>
                        </VBox>
                    </ScrollContainer>

                    <!-- ── MY EXPORTS (FILES) TAB ── -->
                    <ScrollContainer id="exports" horizontal="false" vertical="true" height="100%">
                        <VBox class="sapUiResponsiveMargin drsPageContent">
                            <macros:FilterBar
                                id="exportsFilterBar"
                                metaPath="/DrsFile/@com.sap.vocabularies.UI.v1.SelectionFields"
                                liveMode="false"/>
                            <macros:Table
                                id="exportsTable"
                                metaPath="/DrsFile/@com.sap.vocabularies.UI.v1.LineItem"
                                readOnly="true"
                                enableExport="true"
                                enableAutoColumnWidth="true"
                                variantManagement="Control"
                                p13nMode="Column,Sort,Filter"
                                headerText="My Exports (Files)"
                                filterBar="exportsFilterBar"
                                growingThreshold="20">
                            </macros:Table>
                        </VBox>
                    </ScrollContainer>

                    <!-- ── REPORT AP-01: Vendor Open Items ── -->
                    <ScrollContainer id="report_ap01" horizontal="false" vertical="true" height="100%">
                        <VBox class="sapUiResponsiveMargin drsPageContent">
                            <macros:FilterBar
                                id="reportAP01FilterBar"
                                metaPath="/AP01_VendorOpenItems/@com.sap.vocabularies.UI.v1.SelectionFields"
                                liveMode="false"/>
                            <macros:Table
                                id="reportAP01Table"
                                metaPath="/AP01_VendorOpenItems/@com.sap.vocabularies.UI.v1.LineItem"
                                readOnly="true"
                                enableExport="true"
                                enableAutoColumnWidth="true"
                                variantManagement="Control"
                                p13nMode="Column,Sort,Filter"
                                headerText="AP-01: Vendor Open Items"
                                filterBar="reportAP01FilterBar"
                                growingThreshold="20">
                            </macros:Table>
                        </VBox>
                    </ScrollContainer>

                    <!-- ── REPORT AP-02: Vendor Balances ── -->
                    <ScrollContainer id="report_ap02" horizontal="false" vertical="true" height="100%">
                        <VBox class="sapUiResponsiveMargin drsPageContent">
                            <macros:FilterBar
                                id="reportAP02FilterBar"
                                metaPath="/AP02_VendorBalances/@com.sap.vocabularies.UI.v1.SelectionFields"
                                liveMode="false"/>
                            <macros:Table
                                id="reportAP02Table"
                                metaPath="/AP02_VendorBalances/@com.sap.vocabularies.UI.v1.LineItem"
                                readOnly="true"
                                enableExport="true"
                                enableAutoColumnWidth="true"
                                variantManagement="Control"
                                p13nMode="Column,Sort,Filter"
                                headerText="AP-02: Vendor Balances"
                                filterBar="reportAP02FilterBar"
                                growingThreshold="20">
                            </macros:Table>
                        </VBox>
                    </ScrollContainer>

                    <!-- ── REPORT AP-03: AP Aging Report ── -->
                    <ScrollContainer id="report_ap03" horizontal="false" vertical="true" height="100%">
                        <VBox class="sapUiResponsiveMargin drsPageContent">
                            <macros:FilterBar
                                id="reportAP03FilterBar"
                                metaPath="/AP03_APAgingReport/@com.sap.vocabularies.UI.v1.SelectionFields"
                                liveMode="false"/>
                            <macros:Table
                                id="reportAP03Table"
                                metaPath="/AP03_APAgingReport/@com.sap.vocabularies.UI.v1.LineItem"
                                readOnly="true"
                                enableExport="true"
                                enableAutoColumnWidth="true"
                                variantManagement="Control"
                                p13nMode="Column,Sort,Filter"
                                headerText="AP-03: AP Aging Report"
                                filterBar="reportAP03FilterBar"
                                growingThreshold="20">
                            </macros:Table>
                        </VBox>
                    </ScrollContainer>

